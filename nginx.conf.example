# nginx reverse-proxy config for wifi-billing
# Copy to /etc/nginx/sites-available/wifi-billing and symlink to sites-enabled/
#
# Prerequisites:
#   sudo apt install nginx certbot python3-certbot-nginx
#   sudo certbot --nginx -d yourdomain.co.ke
#
# Replace yourdomain.co.ke with your actual domain throughout.

server {
    listen 80;
    server_name yourdomain.co.ke;

    # Let Certbot handle HTTPS redirect — it will edit this block automatically
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name yourdomain.co.ke;

    # SSL certs — filled in by certbot
    ssl_certificate     /etc/letsencrypt/live/yourdomain.co.ke/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.co.ke/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers (helmet handles most of these in Node, belt-and-suspenders)
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;
    add_header Referrer-Policy no-referrer-when-downgrade;

    # Daraja callbacks must not be rate-limited by nginx — handle in Node
    location /api/v1/payment/callback {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # All other traffic → Node
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        keep-alive;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 30s;

        # Prevent nginx buffering large bodies (M-Pesa STK can be slow)
        proxy_buffering off;
    }

    # Gzip static assets
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1024;
}
