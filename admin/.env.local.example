## Admin (Vite) local env example
##
## 1) Copy to .env.local (or set in your hosting provider)
## 2) Restart `npm run dev`

# Backend API base URL (ends with /api/v1)
# VITE_API_URL=http://localhost:3000/api/v1

# Public portal URL used by MikroTik Hotspot redirect (no /api/v1 here)
# Set this to your portal dev server "Network" URL or your deployed portal domain.
# Example (LAN): http://192.168.1.102:5173
VITE_PORTAL_URL=http://192.168.1.102:5173

