{
  "name": "wifi-billing-server",
  "version": "1.0.0",
  "description": "WiFi Billing System — GlimmerInk Creations",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon --watch server --watch .env server/server.js",
    "build": "npm run build --prefix portal",
    "build:admin": "npm run build --prefix admin",
    "build:all": "npm run build --prefix portal && npm run build --prefix admin",
    "seed:bundles": "node server/scripts/seedBundles.js",
    "seed": "node server/scripts/seedAll.js",
    "check:env": "node -e \"const r=['MONGO_URI','JWT_SECRET','ENCRYPTION_KEY'];const m=r.filter(k=>!process.env[k]);if(m.length){console.error('Missing required env vars:',m.join(', '));process.exit(1);}console.log('Env OK');\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^7.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.4",
    "node-cron": "^3.0.3",
    "node-routeros": "^1.2.2",
    "nodemailer": "^8.0.7",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
