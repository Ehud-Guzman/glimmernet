# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public HTTPS base URL — REQUIRED for Daraja STK/B2C callbacks (e.g. your ngrok URL in dev)
APP_URL=https://your-public-url.example.com

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/wifi-billing

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=7d

# ── Admin Bootstrap ────────────────────────────────────────────────────────────
# Set this TEMPORARILY to seed the first superadmin via POST /api/v1/admin/seed.
# Remove or unset it immediately after the first admin is created — leaving it
# set permanently is a security risk. Leave blank to disable the seed endpoint.
ADMIN_SEED_TOKEN=

# ── Daraja / M-Pesa (env var fallbacks — can also be set in Platform Settings UI) ──
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=

# ── First-run checklist ────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in the values above.
# 2. npm install           (in wifi-billing/)
# 3. npm install           (in portal/)
# 4. npm install           (in admin/)
# 5. npm run build         (in portal/)   ← required: backend serves portal/dist/
# 6. npm run build         (in admin/)    ← required for production admin UI
# 7. Set ADMIN_SEED_TOKEN, start the server, POST /api/v1/admin/seed to create
#    the first superadmin, then REMOVE ADMIN_SEED_TOKEN from .env and restart.
# 8. Log in at localhost:5174 (admin) and configure Platform Settings.

# ── Everything else is configured via the Admin → Platform Settings UI ─────────
#
# On first startup the server seeds default values into MongoDB.
# Log in as superadmin and set these under Platform Settings:
#
#   M-Pesa / Daraja (DB settings override the env vars above when set)
#     daraja_env               sandbox | production
#     daraja_consumer_key
#     daraja_consumer_secret
#     daraja_passkey
#     daraja_shortcode
#     app_url                  (overrides APP_URL env var when set)
#     daraja_b2c_initiator_name
#     daraja_b2c_security_credential
#
#   MikroTik
#     mikrotik_host            Default router IP / hostname
#     mikrotik_user            RouterOS API username
#     mikrotik_pass            RouterOS API password
#     mikrotik_port            8728 (plain) or 8729 (SSL)
#
#   SMS — Africa's Talking
#     at_api_key
#     at_username              'sandbox' for testing
#     at_sandbox               true | false
#     at_sender_id             optional
#     sms_enabled              true | false
#
#   Support
#     support_phone            Fallback number shown on portal / SMS receipts
#     support_email
#
#   Security
#     allowed_origins          Comma-separated CORS origins for production
#
#   Billing
#     platform_fee_percent     % GlimmerInk keeps from each transaction
